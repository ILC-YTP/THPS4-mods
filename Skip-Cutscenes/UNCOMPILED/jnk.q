script TRG_CraneController01Script
  if Inside
    Printf "stopping the cranes"
    if IsAlive Name = TRG_CraneController
      SendFlag prefix = "TRG_CraneController" OBJFLAG_CRANE_DONEMOVE
    endif
  else
    Printf "restarting the cranes"
    if IsAlive Name = TRG_CraneController
      ClearFlag prefix = "TRG_CraneController" OBJFLAG_CRANE_DONEMOVE
    endif
  endif
endscript
